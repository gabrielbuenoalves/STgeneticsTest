@page "/"
@page "/blazor/orders"
@inject HttpClient Http

<div class="space-y-6">
    <div class="space-y-2">
        <p class="text-xs font-bold uppercase tracking-[0.24em] text-amber-600">Pedidos</p>
        <h2 class="text-3xl font-black tracking-tight text-slate-950">Monte seu pedido</h2>
        <p class="max-w-2xl text-sm leading-6 text-slate-600">Escolha um item de cada categoria. O sistema bloqueia duplicados e mostra o erro de negocio de forma legivel.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
            @_error
        </div>
    }

    @if (_menuItems is null)
    {
        <p class="text-slate-500">Carregando cardapio...</p>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="CreateOrderAsync">
            <div class="grid gap-4 lg:grid-cols-3">
                @foreach (var group in _menuItems.GroupBy(item => item.Type))
                {
                    <fieldset class="rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm shadow-slate-200/40">
                        <legend class="rounded-full bg-white px-3 py-1 text-sm font-bold text-slate-900 shadow-sm shadow-slate-200">@GetGroupTitle(group.Key)</legend>

                        <div class="mt-4 space-y-2">
                            @foreach (var item in group)
                            {
                                <label class="flex cursor-pointer items-center gap-3 rounded-2xl border border-transparent bg-white px-4 py-3 text-sm shadow-sm shadow-slate-200/40 transition hover:border-amber-200 hover:bg-amber-50" @key="item.Id">
                                    <input class="h-4 w-4 border-slate-300 text-amber-600 focus:ring-amber-500" type="radio" name="@group.Key" checked="@IsSelected(group.Key, item.Id)" @onchange="() => SelectItem(group.Key, item.Id)" />
                                    <span class="flex-1 text-slate-800">@item.Name</span>
                                    <span class="font-semibold text-slate-900">@item.Price.ToString("C")</span>
                                </label>
                            }
                        </div>
                    </fieldset>
                }
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-3">
                <button type="submit" class="inline-flex items-center rounded-full bg-amber-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-amber-500/20 transition hover:-translate-y-0.5 hover:bg-amber-400">
                    Criar pedido
                </button>
                <span class="text-sm text-slate-500">Selecione pelo menos um sanduiche para concluir o pedido.</span>
            </div>
        </EditForm>
    }

    <hr class="border-slate-200" />

    @if (_orders is null)
    {
        <p class="text-slate-500">Carregando pedidos...</p>
    }
    else if (_orders.Count == 0)
    {
        <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 px-4 py-8 text-center text-slate-500">
            Nenhum pedido cadastrado.
        </div>
    }
    else
    {
        <div class="overflow-hidden rounded-2xl border border-slate-200">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50 text-left text-xs font-bold uppercase tracking-[0.18em] text-slate-500">
                    <tr>
                        <th class="px-4 py-3">ID</th>
                        <th class="px-4 py-3">Itens</th>
                        <th class="px-4 py-3">Subtotal</th>
                        <th class="px-4 py-3">Desconto</th>
                        <th class="px-4 py-3">Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                    @foreach (var order in _orders)
                    {
                        <tr class="transition hover:bg-amber-50/60">
                            <td class="px-4 py-3 font-semibold text-slate-900">@order.Id</td>
                            <td class="px-4 py-3 text-slate-700">@string.Join(", ", order.Items.Select(i => i.Name))</td>
                            <td class="px-4 py-3 font-semibold text-slate-900">@order.Subtotal.ToString("C")</td>
                            <td class="px-4 py-3 font-semibold text-slate-900">@order.DiscountAmount.ToString("C")</td>
                            <td class="px-4 py-3 font-semibold text-slate-900">@order.Total.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private sealed class CreateOrderForm
    {
        public List<int> ItemIds { get; set; } = [];
    }

    private CreateOrderForm _form = new();
    private List<MenuItemResponse>? _menuItems;
    private List<OrderResponse>? _orders;
    private string? _error;
    private readonly Dictionary<string, int> _selectedItemsByType = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _menuItems = await Http.GetFromJsonAsync<List<MenuItemResponse>>("api/menu") ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Erro ao carregar cardapio: {ex.Message}";
            _menuItems = [];
        }

        await LoadOrdersAsync();
    }

    private void SelectItem(string itemType, int itemId)
    {
        _selectedItemsByType[itemType] = itemId;
        _form.ItemIds = _selectedItemsByType.Values.ToList();
    }

    private bool IsSelected(string itemType, int itemId)
    {
        return _selectedItemsByType.TryGetValue(itemType, out var selectedId) && selectedId == itemId;
    }

    private static string GetGroupTitle(string itemType)
    {
        return itemType switch
        {
            "Sandwich" => "Sanduiche",
            "FrenchFries" => "Batata",
            "SoftDrink" => "Refrigerante",
            _ => itemType
        };
    }

    private async Task CreateOrderAsync()
    {
        _error = null;

        var response = await Http.PostAsJsonAsync("api/orders", new CreateOrderRequest
        {
            ItemIds = _form.ItemIds
        });

        if (!response.IsSuccessStatusCode)
        {
            _error = await ExtractErrorMessageAsync(response);
            return;
        }

        _form = new CreateOrderForm();
        _selectedItemsByType.Clear();
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        try
        {
            _orders = await Http.GetFromJsonAsync<List<OrderResponse>>("api/orders") ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Erro ao carregar pedidos: {ex.Message}";
            _orders = [];
        }
    }

    private static async Task<string> ExtractErrorMessageAsync(HttpResponseMessage response)
    {
        var payload = await response.Content.ReadAsStringAsync();

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(payload);

            if (document.RootElement.TryGetProperty("detail", out var detail))
            {
                return detail.GetString() ?? payload;
            }

            if (document.RootElement.TryGetProperty("title", out var title))
            {
                return title.GetString() ?? payload;
            }
        }
        catch
        {
        }

        return payload;
    }
}
